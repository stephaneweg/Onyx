#!/bin/sh
#
# Onyx pre-commit hook -- never let the real Wi-Fi PSK reach git history.
#
# If sdcard/wpa_supplicant.conf is staged, rewrite ONLY the staged blob so the
# committed copy has a redacted psk. The working tree is left untouched: it keeps
# the real key so the SD card still associates. The file is normally also marked
# `skip-worktree` (so `git add` ignores it and git status stays clean) -- this hook
# is the safety net for the case where that flag is lost and the file gets staged.
#
# Install (once per clone):  git config core.hooksPath tools/git-hooks
#
f="sdcard/wpa_supplicant.conf"

if git diff --cached --name-only -z | tr '\0' '\n' | grep -qx "$f"; then
	mode=$(git ls-files --stage "$f" | awk '{print $1}')
	blob=$(git show ":$f" \
		| sed -E 's/^([[:space:]]*psk=)"[^"]*"/\1"REDACTED-set-on-the-SD-card"/' \
		| git hash-object -w --stdin)
	git update-index --cacheinfo "$mode,$blob,$f"
	echo "pre-commit: redacted the Wi-Fi psk in the committed wpa_supplicant.conf"
fi

exit 0
