+// Zircon: replace the active map with another compiled-in country map at runtime.
+boolean CKeyMap::LoadMap (const char *pLocale)
+{
+	const void *pMap = LookupDefaultMap (pLocale);
+	if (pMap == 0)
+	{
+		return FALSE;
+	}
+	memcpy (m_KeyMap, pMap, sizeof m_KeyMap);
+	return TRUE;
+}
