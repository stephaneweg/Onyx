# Circle (the HAL) is a git SUBMODULE -> our fork github.com/stephaneweg/circle,
# branch `onyx` (= upstream Step51 + our patches). It is therefore tracked, not
# ignored. After cloning Onyx:  git submodule update --init  (then build Circle).

# Build artifacts
*.o
*.a
*.d
*.img
*.elf
*.lst
*.map
*.bin

# SD staging: firmware blobs are large/redistributable; keep README + config.txt
*.dat
*.dtb
# WLAN firmware (fetch via circle/addon/wlan/firmware/Makefile, copy to SD:/firmware/)
/sdcard/firmware/
# NetSurf staged onto the card: the .elf (above) + GPL upstream resources regenerated by
# `make -f user/netsurf/netsurf-app.mk stage` -- not committed (see user/netsurf/README.md).
/sdcard/apps/netsurf.app/
/sdcard/res/
# NOTE: sdcard/etc/wpa_supplicant.conf IS tracked, but its psk is redacted on commit
# by the tools/git-hooks/pre-commit hook (+ skip-worktree). The working copy keeps the
# real key for the SD card; the committed copy never does. See tools/git-hooks/README.

# Scratch / reference material (e.g. MenuetOS .asm sources kept for reference)
/temp/

# Editor / tooling
.claude/settings.local.json
.claude/settings.local.json.bak

# Generated by the kernel build (kapi_* symbol export)
user/kernel_syms.ld

# Python bytecode cache
__pycache__/
*.pyc
