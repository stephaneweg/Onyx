# Upstream Circle dependency (HAL): cloned separately into ../circle, NOT vendored
# here (it is ~256 MB / 1700+ files). We pin the exact upstream commit and keep our
# local changes as a tracked patch series -- see circle-patches/README.md to set it
# up (clone @ Step51 + git apply circle-patches/*.patch).
/circle/

# Build artifacts
*.o
*.a
*.d
*.img
*.elf
*.lst
*.map
*.bin

# SD staging: firmware blobs are large/redistributable; keep README + config.txt
*.dat
*.dtb
# WLAN firmware (fetch via circle/addon/wlan/firmware/Makefile, copy to SD:/firmware/)
/sdcard/firmware/
# NOTE: sdcard/wpa_supplicant.conf IS tracked, but its psk is redacted on commit by
# the tools/git-hooks/pre-commit hook (+ skip-worktree). The working copy keeps the
# real key for the SD card; the committed copy never does. See tools/git-hooks/README.

# Scratch / reference material (e.g. MenuetOS .asm sources kept for reference)
/temp/

# Editor / tooling
.claude/settings.local.json
.claude/settings.local.json.bak

# Generated by the kernel build (kapi_* symbol export)
user/kernel_syms.ld

# Python bytecode cache
__pycache__/
*.pyc
