#
# Makefile -- cross-build the NetSurf core libraries for Onyx (aarch64-none-elf + newlib).
# This is NetSurf brick 7: the portable library stack NetSurf is built on. Same split as
# user/tls/ and user/img/ -- the upstream sources are cross-built here (placed as
# ./libwapcaplet, ./libparserutils, ... -- git clones / submodules, NOT committed), the
# only Onyx-side file is gen/ (a gperf-free table, see below). We bypass NetSurf's own
# buildsystem and compile each library's translation units directly.
#
# Build order / dependencies:  libwapcaplet libparserutils libnsutils libnsgif libnsbmp
# are leaves; libhubbub needs libparserutils; libcss needs libwapcaplet+libparserutils;
# libdom needs libwapcaplet+libparserutils+libhubbub. (libnslog is NOT built here: it needs
# flex/bison and is not on the rendering path.)
#
# Code generation (the upstream Makefiles run host tools; we reproduce just what's needed):
#   - libparserutils : src/charset/aliases.inc        via perl  build/make-aliases.pl
#   - libhubbub      : src/tokeniser/entities.inc      via perl  build/make-entities.pl
#                      src/treebuilder/autogenerated-element-type.c -- gperf is unavailable,
#                      so we drop in gen/hubbub-autogenerated-element-type.c (a plain-C table
#                      equivalent; keeps libhubbub unpatched).
#   - libcss         : src/parse/properties/autogenerated_*.c via a HOST tool gen_parser,
#                      compiled from css_property_parser_gen.c with $(BUILD_CC).
#
# Prereqs: the sources placed under this dir (see README.md for versions), perl, and a
# HOSTED x86 compiler for $(BUILD_CC) -- note the toolchain's plain cc/gcc alias the
# aarch64 cross compiler here, so BUILD_CC names the hosted one. Then:  make -C user/netsurf
#
PREFIX   ?= aarch64-none-elf-
CC        = $(PREFIX)gcc
AR        = $(PREFIX)ar
BUILD_CC ?= x86_64-linux-gnu-gcc
PERL     ?= perl
GREP     ?= grep

NS  ?= .
GEN := $(CURDIR)/gen

# Same world as the newlib apps: hardware FP, PIC/SSP off, NOT -nostdlib (these use newlib).
# -fcommon: this code predates GCC 10's -fno-common default and relies on tentative globals
# being merged (e.g. libcss's `_ALIGNED`); without it the property parsers multiply-define it.
CF = -mcpu=cortex-a72 -O2 -std=c99 -fno-pic -fno-pie -fno-stack-protector \
     -ffunction-sections -fdata-sections -fcommon \
     -D_DEFAULT_SOURCE -D_POSIX_C_SOURCE=200112L

I_WAP := -I$(NS)/libwapcaplet/include
I_PU  := -I$(NS)/libparserutils/include
I_HB  := -I$(NS)/libhubbub/include

LIBS := libwapcaplet libparserutils libnsutils libnsgif libnsbmp libhubbub libcss libdom
ARCHIVES := $(foreach l,$(LIBS),$(NS)/$(l)/$(l).a)

.PHONY: all clean
all: $(ARCHIVES)

# generic compile -- each object group sets its own -I via the target-specific CINC below.
%.o: %.c
	$(CC) $(CF) $(CINC) -c $< -o $@

# ---- leaf libraries (no codegen) ---------------------------------------
WAP_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libwapcaplet/src -name '*.c'))
$(WAP_OBJ): CINC := $(I_WAP) -I$(NS)/libwapcaplet/src
$(NS)/libwapcaplet/libwapcaplet.a: $(WAP_OBJ); $(AR) rcs $@ $^

NSU_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libnsutils/src -name '*.c'))
$(NSU_OBJ): CINC := -I$(NS)/libnsutils/include -I$(NS)/libnsutils/src
$(NS)/libnsutils/libnsutils.a: $(NSU_OBJ); $(AR) rcs $@ $^

GIF_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libnsgif/src -name '*.c'))
$(GIF_OBJ): CINC := -I$(NS)/libnsgif/include -I$(NS)/libnsgif/src
$(NS)/libnsgif/libnsgif.a: $(GIF_OBJ); $(AR) rcs $@ $^

BMP_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libnsbmp/src -name '*.c'))
$(BMP_OBJ): CINC := -I$(NS)/libnsbmp/include -I$(NS)/libnsbmp/src
$(NS)/libnsbmp/libnsbmp.a: $(BMP_OBJ); $(AR) rcs $@ $^

# ---- libparserutils (perl: charset alias table) ------------------------
$(NS)/libparserutils/src/charset/aliases.inc:
	cd $(NS)/libparserutils && $(PERL) build/make-aliases.pl
# -DWITHOUT_ICONV_FILTER: use libparserutils' OWN charset codecs (utf8/utf16/8859/ext8/
# ascii) for the input filter instead of the host's iconv (newlib has none). Covers the
# common web encodings; drops the iconv/iconv_open/iconv_close link dependency.
PU_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libparserutils/src -name '*.c'))
$(PU_OBJ): CINC := $(I_PU) -I$(NS)/libparserutils/src -DWITHOUT_ICONV_FILTER
$(PU_OBJ): | $(NS)/libparserutils/src/charset/aliases.inc
$(NS)/libparserutils/libparserutils.a: $(PU_OBJ); $(AR) rcs $@ $^

# ---- libhubbub (perl: entities; plain-C element-type table) ------------
$(NS)/libhubbub/src/tokeniser/entities.inc:
	cd $(NS)/libhubbub && $(PERL) build/make-entities.pl
$(NS)/libhubbub/src/treebuilder/autogenerated-element-type.c: $(GEN)/hubbub-autogenerated-element-type.c
	cp $< $@
HB_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libhubbub/src -name '*.c' ! -name 'autogenerated-element-type.c'))
$(HB_OBJ): CINC := $(I_HB) -I$(NS)/libhubbub/src $(I_PU)
$(HB_OBJ): | $(NS)/libhubbub/src/tokeniser/entities.inc $(NS)/libhubbub/src/treebuilder/autogenerated-element-type.c
$(NS)/libhubbub/libhubbub.a: $(HB_OBJ); $(AR) rcs $@ $^

# ---- libcss (host gen_parser -> per-property parser sources) -----------
CSS_GENDIR := $(NS)/libcss/src/parse/properties
$(NS)/libcss/build/gen_parser: $(CSS_GENDIR)/css_property_parser_gen.c
	$(BUILD_CC) -O2 -o $@ $<
$(CSS_GENDIR)/autogenerated_%.c: $(NS)/libcss/build/gen_parser $(CSS_GENDIR)/properties.gen
	cd $(NS)/libcss && build/gen_parser -o $(CSS_GENDIR)/autogenerated_$*.c "$$($(GREP) "^$*:" $(CSS_GENDIR)/properties.gen)"
CSS_AUTONAMES := $(shell $(PERL) -pe '$$_="" unless /^([^\#][^:]+):/;$$_=$$1 . " "' $(CSS_GENDIR)/properties.gen)
CSS_AUTO_C := $(addprefix $(CSS_GENDIR)/autogenerated_,$(addsuffix .c,$(CSS_AUTONAMES)))
CSS_SRC := $(filter-out %css_property_parser_gen.c,$(shell find $(NS)/libcss/src -name '*.c' ! -name 'autogenerated_*.c')) $(CSS_AUTO_C)
CSS_OBJ := $(CSS_SRC:.c=.o)
$(CSS_OBJ): CINC := -I$(NS)/libcss/include -I$(NS)/libcss/src $(I_WAP) $(I_PU)
$(NS)/libcss/libcss.a: $(CSS_OBJ); $(AR) rcs $@ $^

# ---- libdom (+ the hubbub HTML binding, which NetSurf drives via dom_hubbub_parser_*) --
# The binding lives in libdom/bindings/hubbub/ (not src/) and must be compiled with libdom's
# OWN includes -- NetSurf also has a utils/, so it must NOT see -Inetsurf.
DOM_OBJ := $(patsubst %.c,%.o,$(shell find $(NS)/libdom/src -name '*.c') $(wildcard $(NS)/libdom/bindings/hubbub/*.c))
# NB: do NOT add -I.../bindings -- the binding's own dir is bindings/hubbub/, which would
# shadow libhubbub's <hubbub/*.h>. Its "parser.h"/"utils.h" are found same-dir (quoted).
$(DOM_OBJ): CINC := -I$(NS)/libdom/include -I$(NS)/libdom/src $(I_WAP) $(I_PU) $(I_HB)
$(NS)/libdom/libdom.a: $(DOM_OBJ); $(AR) rcs $@ $^

clean:
	rm -f $(WAP_OBJ) $(NSU_OBJ) $(GIF_OBJ) $(BMP_OBJ) $(PU_OBJ) $(HB_OBJ) $(CSS_OBJ) $(DOM_OBJ) $(ARCHIVES)
	rm -f $(NS)/libcss/build/gen_parser $(CSS_AUTO_C)
	rm -f $(NS)/libparserutils/src/charset/aliases.inc $(NS)/libhubbub/src/tokeniser/entities.inc
	rm -f $(NS)/libhubbub/src/treebuilder/autogenerated-element-type.c
