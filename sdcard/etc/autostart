# autostart.txt -- programs started automatically at boot, one per line.
#
# Each line is a shell command, run like in the terminal: the first word is a /bin
# tool (/bin/<word>.elf) and the rest are its arguments. Launch a DESKTOP app with
# the `run` tool. Blank lines and '#' comments are ignored.
#
#   run voronoy   -> /bin/run.elf voronoy  -> launches apps/voronoy.app/main.elf
#   run panel     -> launches apps/panel.app/main.elf (the shell)
#   keyb FR       -> /bin/keyb.elf FR      -> set the French keyboard layout
#
run voronoy
run panel
keyb FR
